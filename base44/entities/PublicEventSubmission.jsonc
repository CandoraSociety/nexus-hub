{
  "name": "PublicEventSubmission",
  "type": "object",
  "properties": {
    "submitter_name": {
      "type": "string",
      "description": "Name of person submitting"
    },
    "submitter_email": {
      "type": "string",
      "description": "Submitter email"
    },
    "organization_name": {
      "type": "string",
      "description": "Organization or company name"
    },
    "organization_type": {
      "type": "string",
      "enum": [
        "nonprofit",
        "business",
        "government",
        "individual",
        "other"
      ],
      "description": "Type of submitting organization"
    },
    "website": {
      "type": "string",
      "description": "Submitter or org website"
    },
    "event_name": {
      "type": "string",
      "description": "Event name"
    },
    "event_description": {
      "type": "string",
      "description": "Full event description"
    },
    "event_type": {
      "type": "string",
      "description": "Type of event"
    },
    "start_date": {
      "type": "string",
      "format": "date-time",
      "description": "Event start date and time"
    },
    "end_date": {
      "type": "string",
      "format": "date-time",
      "description": "Event end date and time"
    },
    "location": {
      "type": "string",
      "description": "Event location"
    },
    "expected_attendance": {
      "type": "number",
      "description": "Expected number of attendees"
    },
    "ticket_tiers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "description": "Proposed ticket tiers"
    },
    "agreed_to_fee_structure": {
      "type": "boolean",
      "default": false,
      "description": "Submitter agreed to platform fee structure"
    },
    "billing_name": {
      "type": "string",
      "description": "Legal name or organization for payout"
    },
    "billing_address": {
      "type": "string",
      "description": "Payout street address"
    },
    "billing_city": {
      "type": "string",
      "description": "Payout city"
    },
    "billing_state": {
      "type": "string",
      "description": "Province (Canadian)"
    },
    "billing_zip": {
      "type": "string",
      "description": "Postal code"
    },
    "billing_country": {
      "type": "string",
      "default": "CA",
      "description": "Country (default Canada)"
    },
    "payout_transit": {
      "type": "string",
      "description": "Canadian bank transit number (5 digits)"
    },
    "payout_institution": {
      "type": "string",
      "description": "Canadian bank institution number (3 digits)"
    },
    "payout_account": {
      "type": "string",
      "description": "Canadian bank account number"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "needs_revision"
      ],
      "default": "pending",
      "description": "Review status"
    },
    "linked_event_id": {
      "type": "string",
      "description": "If approved, the created Event ID"
    },
    "admin_notes": {
      "type": "string",
      "description": "Internal admin notes or rejection reason"
    }
  },
  "required": [
    "submitter_name",
    "submitter_email",
    "event_name",
    "start_date"
  ]
}